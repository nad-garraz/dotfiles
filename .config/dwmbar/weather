#!/bin/sh

weatherreport="${XDG_DATA_HOME:-$HOME/.local/share}/weatherreport"
getforecast() {
	curl -sf "wttr.in/$LOCATION" > "$weatherreport" || exit 1 ;
}

showweather() {
	printf "%s " "$(sed '16q;d' "$weatherreport" |
		grep -wo "[0-9]*%" | sort -rn | sed "s/^/☔:/g;1q" | tr -d '\n')"
			sed '13q;d' "$weatherreport" | grep -o "m\\([-+]\\)*[0-9]\\+" | sort -n -t 'm' -k 2n | sed -e 1b -e '$!d' | tr '\n|m' ' ' | awk '{ print "🥶:"$1"°""🌞:"$2"° " }' ;}

			case $BUTTON in
				1) setsid -f alacritty --class float,term -d 125 39 -e less -Srf "$weatherreport"
					;;
				2) notify-send "⛅ Refreshing...";
					getforecast && showweather
					;;
				3) notify-send "🌈 Weather module" "Temperatura: $(curl -s wttr.in/$LOCATION?format=1 | sed "s/^. \+\?//g")"
					;;
				6) setsid -f "$TERMINAL" -e "$EDITOR" "$0"
					;;
			esac

# The test if our forecast is updated to the day. If it isn't download a new
# weather report from wttr.in with the above function.
[ "$(stat -c %y "$weatherreport" 2>/dev/null | cut -d' ' -f1)" = "$(date '+%Y-%m-%d')" ] || getforecast

showweather
