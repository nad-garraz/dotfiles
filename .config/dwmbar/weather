#!/bin/sh
LOCATION="-36.9267019,175.7895731"

olderAndIp () {
		# Update solo con inet y si el último update son más viejos que la edad objetivo
		showweather;
		{ [ $(expr $(date "+%s") - $(stat -c %Y "$temp")) -ge 3600 ] || [ $(expr $(date "+%s") - $(stat -c %Y "$weatherreport")) -ge 7200 ] ; } && ping -q -c 1 1.1.1.1 >/dev/null 2>&1 &&
			rm $temp $weatherreport
		}

showweather() {
	printf "%s " "$(sed '16q;d' "$weatherreport" |
		grep -wo "[0-9]*%" | sort -rn | sed "s/^/☔:/g;1q" | tr -d '\n')"
				sed '13q;d' "$weatherreport" | grep -o "m\\([-+]\\)*[0-9]\\+" | sort -n -t 'm' -k 2n | sed -e 1b -e '$!d' | tr '\n|m' ' ' | awk '{ print "🥶:"$1"°""🌞:"$2"° " }' ;}

getforecast() {
		{ [ -z "$(cat $weatherreport)" ] || olderAndIp  ;} &&
			curl -sf "wttr.in/$LOCATION" > "$weatherreport" &&
		uptime="$(date -d "$(stat -c %x "$weatherreport")" '+%D at %T' | sed "s|$(date '+%D')|Today|")" &&
		echo -e "${RED}Last update: ${uptime}${NC}" >> $weatherreport
}

temperaturaActual () {
	{ [ -z "$(cat $temp)" ] || olderAndIp ;} &&
		uptime="$(date -d "$(stat -c %x "$temp")" '+%D at %T' | sed "s|$(date '+%D')|Today|")" &&
		echo -e "Temperatura: $(curl -s wttr.in/$LOCATION?format=1 | sed "s/^. \+\?//g")\n<b>Last update:</b>\n${uptime}" > $temp ;
		}



weatherreport="${XDG_DATA_HOME:-$HOME/.local/share}/weatherreport"
temp="$HOME/.local/share/local_temperature"

case $BUTTON in
	3) setsid -f alacritty --class float,term -d 125 42 -e less -Srf "$weatherreport";;
	2) notify-send -t 2000 "⛅ Refreshing..."; getforecast && temperaturaActual;;
	1) notify-send "🌈 Weather module" "$(cat $temp)";;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0";;
esac

[ ! -e "$weatherreport" ] && touch "$weatherreport" && getforecast
[ ! -e "$temp" ] && touch "$temp"&& temperaturaActual

olderAndIp && getforecast && temperaturaActual;
showweather
