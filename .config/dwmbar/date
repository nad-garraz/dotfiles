#!/bin/sh


calendar="${XDG_DATA_HOME:-$HOME/.local/share}/calendar"

# Calendario anual, lunes primer día.
getCalendar () {
	LANG=es_AR.UTF-8 \cal -y -m --color=always > "$calendar"
}

case $BUTTON in
	3) notify-send -t 3000 "♻  Loading..." && $HOME_SCRIPTS/basicos/horarios;;
	2) notify-send "🗓  Calendario actualizado" && getCalendar;;
	1) setsid -f falacritty less -Srf "$calendar";;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0";;
esac

printf "📅%s " "$(date "+%a %-d/%-m %-H:%M")"

[ "$(stat -c %y "$calendar" 2> /dev/null | cut -d' ' -f1)" = "$(date '+%Y-%m-%d')" ] ||
	getCalendar
