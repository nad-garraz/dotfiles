#!/bin/sh

icon="☠"

# Si el transmission está prendido, muestra el icono.
pgrep transmission-da > /dev/null && printf "%s " "$icon"


toggle_list () {
	rows=$(( $(transmission-remote -l | wc -l) + 1 ))
	pidof watch && killall watch || setsid -f falacritty -d 170 $rows -e watch -d -n 1 -t -c transmission-remote -l
}


case $BUTTON in
	1) toggle_list ;;
	3) setsid -f torrent_dmenu;;
	6) setsid -f "$TERMINAL" -e "$EDITOR" "$0" ;;
esac
