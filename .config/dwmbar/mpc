#!/bin/sh

musicOn () {
	i=$(date "+%S")
	if [ $(expr $i % 3 ) -eq 0 ]; then
		echo "🎶♫ "
	else
		echo "♫🎶 "
	fi
}

dancingMan () {
	if [ $(expr $1 % 2 ) -eq 0 ]; then
		echo "    ♪╔(・o･)╝♪♫  ♩♩♫~(◠o◠)~♫ \n======================================"

	else
		echo "  ♫♪ ╚(･o・)╗ ♪  ♩~(◠0◠)~♫ ♩♫\n--------------------------------------"
	fi
}

ARTIST=$(mpc current -f %artist%)
TRACK=$(mpc current -f %title%)
STATUS=$(mpc status | sed -n 2p | awk '{print $1;}')
NEXT=$(mpc queued)
[ "$STATUS" = "[playing]" ] &&	musicOn

notifyInfo () {
	i=10
	while [ $i -gt 0 ];do
		read now <<< $(mpc status | awk '/^\[/ { printf $3 "\t" $4}')
		dunstify -r 1 "🎶$ARTIST
  $TRACK" "  $now
$(dancingMan $i)
Next song: $NEXT "
		let i=$(echo "$i-1" | bc -ql) 1> /dev/null
		sleep 1
	done
}


case $BUTTON in
	1) notifyInfo;;
	6) "$TERMINAL" -e "$EDITOR" "$0"
esac
