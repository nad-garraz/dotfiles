alias reflector='sudo reflector --latest 100 --age 24 --verbose --protocol http --protocol https --sort rate --save /etc/pacman.d/mirrorlist'


# Pasa los mp3 a menor calidad
alias superlame64='{ for f in *; do lame --mp3input -b 64 "$f" tmp && \mv tmp "$f"; done; }'
alias superlame128='{ for f in *; do lame --mp3input -b 128 "$f" tmp && \mv tmp "$f"; done; }'
alias superlame192='{ for f in *; do lame --mp3input -b 192 "$f" tmp && \mv tmp "$f"; done; }'

alias abook='com.github.geigi.cozy'

#Bluetoothcontrol
alias bl='bluetoothctl'

alias firefox='TZ=UTC firefox'

# transmission-torrent
alias trc='transmission-remote-cli'

# PACCACHE, borra los paquetes de programas que no están
# instalados y deja solo la última versión de los paquetes
# que sí lo están.
alias limpiarpaquetes="sudo paccache -rk1"

# EXPAC, muestra los últimos paquetes instalados
alias ultimospaquetes="expac --timefmt=%s '%l\t%n' | sort -n"

# espeak in spanish
alias espeak="espeak -ves-la"

# Para el bare git repository
alias bkp="/usr/bin/git --git-dir=/home/test/dotfiles/ --work-tree=/home/test"
alias bkpc="bkp commit -m"
alias bkpa="bkp add"

# MEGA
