alias megaput="megaput --config=$HOME_CONFIG/megarc"
alias megaget="megaget --config=$HOME_CONFIG/megarc"

# VIM --> NVIM
alias vim="nvim"

# La platita
alias guitarra="python ~/programitas/python_projects/guita/main.py"

# Funciones muy útiles:
# Abrir un archivo de mi home directory con el neovim
vf(){ find $HOME -type f | fzf | xargs -r -I % $EDITOR %; }
# Abrir sesiones de mi home directory con el neovim
vs(){ find $HOME -name "*.vim" | fzf | xargs -r -I % $EDITOR -S %; }
# REMOVE VIM SWAP FILES
rvs(){ find $HOME -name "*.swp" | fzf | xargs -r -I % rm %; dustify -r 112 "Se eliminó la swap"; }

# Ps que tanto uso
alias pies="pstree -apC age | grep $1"

# youtube-dl audio
alias yt="youtube-dl --add-metadata -i"
alias yta="yt -x -f bestaudio/best"

# Corona Curl
alias corona="curl -s https://corona-stats.online/{us,ar,es,it,nz,cn,ca,br,cl,in,tw,kr,jp}?minimal=true | grep -A1 Rank > ~/corona && grep -v \"\-\-\" ~/corona && \mv ~/corona /tmp"

# Para ver la cantidad de filas que hay en el directorio
alias filas="ls -a | awk '{rows++} END {print \"Archivos: \" rows }'"
