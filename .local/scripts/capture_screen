#!/usr/bin/env bash


# Screen-shot, capture-screen

# Variables:
TIMESTAMP="$(date +%d-%m-%Y-%H:%M)"
TARGETBASE="/data/pictures/screenshots"
SHUTTER="/data/music/sounds/shutter.mp3"
# Crea el directorio si no lo encuentra:´
[ -d $TARGETBASE ] || mkdir -p $TARGETBASE

# Comando:
[ ! -z "$SHUTTER" ] && \mpv --msg-level=all=no $SHUTTER &
import -window root $TARGETBASE/$TIMESTAMP.png &&
action=$(dunstify --action="dragon,picture" "📸 Screenshot guardada en:" "$TARGETBASE/$TIMESTAMP.png")
case $action in
	"dragon") dragon -x "$TARGETBASE/$TIMESTAMP.png";;
esac
