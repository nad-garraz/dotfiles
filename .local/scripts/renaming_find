#mv "$1" "$(echo "$1" | sed -r "s/[0-9]{2}[-\.]?//g"  | sed -r "s/([A-Z])/\l\1/g" | tr " " "_")"

#mv "$1" "$(echo "$1" | sed -r "s/^\.\/_//1")"


