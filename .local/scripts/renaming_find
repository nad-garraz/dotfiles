#!/bin/sh

# Comandos para reemplazar nombres con fing

# USAGE: ""find . -maxdepth 1 -name "..." -exec renaming {} \;""


## Renames 'XX - ' to '' , cambia espacio a "_" y pasa a minúsculas
mv "$1" "$(echo "$1" | sed -r "s/^([0-9]{4}[ab]-)//g" | sed -r "s/([A-Z])/\l\1/g" | tr " " "_")"
#mv "$1" "$(echo "$1" | sed -r "s/^[0-9]{2}-//g")"


